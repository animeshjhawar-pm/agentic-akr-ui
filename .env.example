# gw_stormbreaker read-only Postgres -- used to query lead/page/customer metrics
DATABASE_URL=

# Supabase Postgres shared run store -- both this UI and the execution engine must point here
RUN_STORE_URL=

# Login password gate -- users enter this at /login to access the UI
APP_SHARED_SECRET=

# Optional: polling interval in ms for run status updates (default 2000)
NEXT_PUBLIC_POLL_INTERVAL_MS=2000
